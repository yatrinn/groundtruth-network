# Supabase — Postgres database, auth, and storage
# Get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# MoneyDevKit — Lightning paywall and agent wallet
# Get these from https://docs.moneydevkit.com
MDK_API_KEY=
MDK_NETWORK=testnet

# Tavily — search API used by the demo agent for grounding before falling back to GroundTruth
# Get yours at https://tavily.com
TAVILY_API_KEY=

# OpenAI — used by the demo agent
OPENAI_API_KEY=

# Public site URL — used to build absolute callback links
NEXT_PUBLIC_SITE_URL=http://localhost:3000
